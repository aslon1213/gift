{
    "$schema": "https://schema.railpack.com",
    "steps": {
        "install": {
            "inputs": [
                {
                    "local": true,
                    "include": [
                        "."
                    ]
                }
            ],
            "commands": [
                "npm install"
            ]
        },
        "build": {
            "inputs": [
                {
                    "step": "install"
                }
            ],
            "commands": [
                "npm run build"
            ]
        }
    },
    "deploy": {
        "startCommand": "npx vite preview --host 0.0.0.0 --port ${PORT:-4173}"
    }
}