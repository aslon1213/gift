{
    "$schema": "https://schema.railpack.com",
    "provider": "node",
    "packages": {
        "node": "25.8.2"
    },
    "steps": {
        "install": {
            "commands": [
                "npm ci"
            ],
            "caches": [
                "npm"
            ]
        },
        "build": {
            "inputs": [
                {
                    "step": "install"
                }
            ],
            "commands": [
                "npm run build"
            ]
        }
    },
    "deploy": {
        "inputs": [
            {
                "step": "build"
            }
        ],
        "variables": {
            "RAILPACK_SPA_OUTPUT_DIR": "dist"
        }
    }
}