{
    "$schema": "https://schema.railpack.com",
    "steps": {
        "install": {
            "commands": [
                "go mod tidy"
            ]
        },
        "build": {
            "inputs": [
                {
                    "step": "install"
                }
            ],
            "commands": [
                "go build -o ./bin/main ./cmd/main.go"
            ]
        }
    },
    "deploy": {
        "startCommand": "./bin/main"
    }
}